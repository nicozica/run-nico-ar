---
import LatestSessionPanel from "../components/LatestSessionPanel.astro";
import LapsPreviewPanel from "../components/LapsPreviewPanel.astro";
import NextRunPanel from "../components/NextRunPanel.astro";
import RaceContextPanel from "../components/RaceContextPanel.astro";
import SignalCardPanel from "../components/SignalCardPanel.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import UsefulReadsPanel from "../components/UsefulReadsPanel.astro";
import WeeklySnapshotPanel from "../components/WeeklySnapshotPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadDashboardData } from "../lib/data/load-dashboard";
import { buildSessionSlug } from "../lib/data/pacer-cms";

const dashboard = await loadDashboardData();
const latestSessionPath = dashboard.latestSession
  ? `/sessions/${buildSessionSlug(dashboard.latestSession.date, dashboard.latestSession.title, null)}/`
  : null;
---

<BaseLayout
  title="nico://run | training, interpreted"
  description={dashboard.site.heroBody}
>
  <SiteHeader site={dashboard.site} currentPath="/" />

  <main id="content" class="page-shell">
    <section class="panel panel--hero featured-session" aria-labelledby="run-hero-heading">
      <LatestSessionPanel
        latestSession={dashboard.latestSession}
        coachFeedback={dashboard.coachFeedback}
        sessionPath={latestSessionPath}
        variant="featured"
      />

      <div class="featured-session__body">
        <SignalCardPanel
          canonicalOutput={dashboard.canonicalOutput}
          insight={dashboard.derivedInsights.latest}
          sessionPath={latestSessionPath}
          variant="embedded"
        />
        <LapsPreviewPanel latestSession={dashboard.latestSession} variant="embedded" />
      </div>
    </section>

    <div class="content-grid content-grid--support content-grid--training">
      <WeeklySnapshotPanel weeklySnapshot={dashboard.weeklySnapshot} />
      <NextRunPanel nextRun={dashboard.nextRun} />
    </div>

    <div class="content-grid content-grid--support content-grid--support-secondary">
      <RaceContextPanel raceContext={dashboard.raceContext} />
      <UsefulReadsPanel usefulReads={dashboard.usefulReads} variant="compact" />
    </div>
  </main>

  <SiteFooter site={dashboard.site} />
</BaseLayout>
