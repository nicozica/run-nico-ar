---
const destination = "/runs/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={new URL(destination, Astro.site ?? "https://run.nico.ar")} />
    <title>Redirecting to Runs</title>
  </head>
  <body>
    <p><a href={destination}>Continue to Runs</a></p>
  </body>
</html>
