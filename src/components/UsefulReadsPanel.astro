---
import type { UsefulRead } from "../lib/data/types";

interface Props {
  usefulReads: UsefulRead[];
  variant?: "default" | "compact";
}

const { usefulReads, variant = "default" } = Astro.props;
const items = variant === "compact" ? usefulReads.slice(0, 5) : usefulReads;

const topicClass: Record<string, string> = {
  running: "topic-badge--running",
  training: "topic-badge--training",
  wellness: "topic-badge--wellness",
  cycling: "topic-badge--cycling",
};
---

<section class={`panel reads-panel ${variant === "compact" ? "reads-panel--compact" : ""}`} aria-labelledby="useful-reads-heading">
  <div class="panel__header">
    <div class={variant === "compact" ? "panel-heading panel-heading--tight" : "panel-heading"}>
      <p class="eyebrow">{variant === "compact" ? "Reads" : "Useful reads"}</p>
      <h2 id="useful-reads-heading">{variant === "compact" ? "Mini feed" : "Worth reading"}</h2>
    </div>

    {variant !== "compact" && <p class="panel__meta">Cached from RSS at build time</p>}
  </div>

  {items.length > 0 ? (
    <ul class="reads-list">
      {items.map((item) => (
        <li class="reads-item">
          <a class="reads-link" href={item.url} target="_blank" rel="noreferrer noopener">
            <span class="reads-link__title">{item.title}</span>
            <span class="reads-link__meta">
              {item.topic && (
                <span class:list={["topic-badge", topicClass[item.topic] ?? ""]}>
                  {item.topic}
                </span>
              )}
              <span>{item.source}</span>
              {item.publishedLabel && <span>{item.publishedLabel}</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="panel-copy">No feed snapshot available yet. The build will use cached or mock reads until the RSS sources respond.</p>
  )}
</section>
