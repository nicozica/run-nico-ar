---
import WeatherGlyph from "./WeatherGlyph.astro";
import type { CoachFeedback, LatestSession } from "../lib/data/types";

interface Props {
  latestSession: LatestSession;
  coachFeedback: CoachFeedback;
}

const { latestSession, coachFeedback } = Astro.props;

// Format date: "2026-03-15" → "Sun 15 Mar"
// Use noon UTC to avoid timezone shifts on the date boundary
const sessionDate = new Date(`${latestSession.date}T12:00:00Z`);
const dateLabel = sessionDate.toLocaleDateString("en-US", {
  weekday: "short",
  day: "numeric",
  month: "short",
});

const sessionTitle = latestSession.title.toUpperCase();

// Eyebrow line: activity type · date · location (omit nulls)
const eyebrowParts = [latestSession.activityType, dateLabel, latestSession.locationLabel].filter(Boolean);
const eyebrow = eyebrowParts.join(" · ");

// Personal note: prefer hand-written note, fall back to overall feeling
const logEntry = latestSession.personalNote ?? latestSession.overallFeeling;

// Coach callout text
const calloutHeadline = coachFeedback.headline;
const calloutParagraph = [coachFeedback.mainTakeaway, logEntry].filter(Boolean).join(" ");

// Route points are normalized during data prep into a compact 160x90 space.
// Keep the SVG viewBox aligned with that coordinate system and scale visually with CSS.
const ROUTE_W = 160;
const ROUTE_H = 90;

const hasRoute = Boolean(latestSession.routeSvgPoints);

function getWeatherKind(label: string | null | undefined): "clear" | "cloudy" | "overcast" | "rain" | "storm" | "mixed" {
  const value = (label ?? "").toLowerCase();

  if (value.includes("storm")) {
    return "storm";
  }

  if (value.includes("rain") || value.includes("drizzle")) {
    return "rain";
  }

  if (value.includes("overcast")) {
    return "overcast";
  }

  if (value.includes("cloud")) {
    return "cloudy";
  }

  if (value.includes("clear") || value.includes("sun") || value.includes("warm") || value.includes("cool")) {
    return "clear";
  }

  return "mixed";
}
---

<section class="panel panel--hero run-hero" aria-labelledby="run-hero-heading">
  <div class="run-hero__header">
    {hasRoute && (
      <svg
        class="run-hero__trace"
        viewBox={`0 0 ${ROUTE_W} ${ROUTE_H}`}
        aria-hidden="true"
        role="img"
      >
        <polyline
          class="run-hero__trace-path"
          points={latestSession.routeSvgPoints!}
        />
      </svg>
    )}

    <div class="run-hero__title-group">
      <p class="eyebrow">{eyebrow}</p>
      <h1 id="run-hero-heading" class="run-hero__title">{sessionTitle}</h1>
    </div>

  </div>

  <dl class="run-stat-row run-stat-row--primary">
    <div class="run-stat run-stat--primary">
      <dt>Distance</dt>
      <dd>{latestSession.distanceKm === null ? "—" : `${latestSession.distanceKm.toFixed(1)} km`}</dd>
    </div>
    <div class="run-stat run-stat--primary">
      <dt>Duration</dt>
      <dd>{latestSession.durationLabel}</dd>
    </div>
    <div class="run-stat run-stat--primary">
      <dt>Pace</dt>
      <dd>{latestSession.paceLabel ?? "—"}</dd>
    </div>
  </dl>

  <dl class="run-stat-row run-stat-row--secondary">
    <div class="run-stat">
      <dt>Heart rate</dt>
      <dd>
        {latestSession.averageHeartRate === null
          ? "—"
          : `${latestSession.averageHeartRate} / ${latestSession.maxHeartRate ?? "—"} bpm`}
      </dd>
    </div>
    <div class="run-stat">
      <dt>Elevation</dt>
      <dd>{latestSession.elevationMeters === null ? "—" : `+${latestSession.elevationMeters} m`}</dd>
    </div>
    <div class="run-stat">
      <dt>Conditions</dt>
      <dd class="run-condition">
        <WeatherGlyph kind={getWeatherKind(latestSession.weatherLabel)} className="run-condition__icon" />
        <span>{latestSession.weatherLabel ?? "—"}</span>
      </dd>
    </div>
  </dl>

  <blockquote class="coach-callout">
    <p class="coach-callout__headline">{calloutHeadline}</p>
    {calloutParagraph && <p class="coach-callout__body">{calloutParagraph}</p>}
  </blockquote>

  {latestSession.laps.length > 0 && (
    <div class="lap-section">
      <p class="eyebrow lap-section__label">
        Splits / {latestSession.laps.length} {latestSession.laps.length === 1 ? "lap" : "laps"}
      </p>
      <div class="lap-table-wrap">
        <table class="lap-table">
          <thead>
            <tr>
              <th scope="col">#</th>
              <th scope="col">km</th>
              <th scope="col">Pace</th>
              <th scope="col">Time</th>
              <th scope="col">HR</th>
            </tr>
          </thead>
          <tbody>
            {latestSession.laps.map((lap) => (
              <tr>
                <td class="lap-table__num">{lap.lapNumber}</td>
                <td>{lap.distanceKm === null ? "—" : lap.distanceKm.toFixed(1)}</td>
                <td>{lap.paceLabel ?? "—"}</td>
                <td>{lap.durationLabel}</td>
                <td>{lap.averageHeartRate ?? "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

</section>
