---
import WeatherGlyph from "./WeatherGlyph.astro";
import RouteTrace from "./RouteTrace.astro";
import type { CoachFeedback, LatestSession } from "../lib/data/types";
import { formatSessionDateLabel, formatSessionTimeLabel } from "../lib/data/session-display.ts";

interface Props {
  latestSession: LatestSession;
  coachFeedback: CoachFeedback;
  sessionPath?: string | null;
  readingParagraphs?: string[];
  carryForward?: string | null;
  nextRunTitle?: string | null;
  nextRunSummary?: string | null;
  variant?: "home" | "detail" | "featured";
}

const {
  latestSession,
  coachFeedback,
  sessionPath = null,
  readingParagraphs = [],
  carryForward = null,
  nextRunTitle = null,
  nextRunSummary = null,
  variant = "home"
} = Astro.props;

const dateLabel = formatSessionDateLabel(latestSession.date);

const sessionTitle = latestSession.title.toUpperCase();
const titleEmojiTokenPattern = /^(?:[\u{1F1E6}-\u{1F1FF}]{2}|\p{Emoji_Presentation}|\p{Extended_Pictographic}\uFE0F?)$/u;
const titleEmojiSplitPattern = /([\u{1F1E6}-\u{1F1FF}]{2}|\p{Emoji_Presentation}|\p{Extended_Pictographic}\uFE0F?)/gu;
const sessionTitleParts = sessionTitle
  .split(titleEmojiSplitPattern)
  .filter((part) => part.length > 0)
  .map((part) => ({
    text: part,
    isEmoji: titleEmojiTokenPattern.test(part)
  }));

// Meta line: date · time · location (omit nulls)
const eyebrowParts = [
  dateLabel,
  formatSessionTimeLabel(latestSession.startDateLocal),
  latestSession.locationLabel
].filter(Boolean);
const eyebrow = eyebrowParts.join(" · ");

// Coach callout text
const calloutParagraph = coachFeedback.summaryShort || coachFeedback.mainTakeaway;
const hasRoute = Boolean(latestSession.routeSvgPoints);
const isRace = latestSession.statusLabel?.trim().toLowerCase() === "race";

function getWeatherKind(label: string | null | undefined): "clear" | "cloudy" | "overcast" | "rain" | "storm" | "mixed" {
  const value = (label ?? "").toLowerCase();

  if (value.includes("storm")) {
    return "storm";
  }

  if (value.includes("rain") || value.includes("drizzle")) {
    return "rain";
  }

  if (value.includes("overcast")) {
    return "overcast";
  }

  if (value.includes("cloud")) {
    return "cloudy";
  }

  if (value.includes("clear") || value.includes("sun") || value.includes("warm") || value.includes("cool")) {
    return "clear";
  }

  return "mixed";
}
---

<section class={`${
  variant === "featured"
    ? "run-hero run-hero--featured"
    : `panel panel--hero run-hero ${variant === "detail" ? "run-hero--detail" : "run-hero--home"}`
}`} aria-labelledby="run-hero-heading">
  <div class="run-hero__header">
    {hasRoute && (
      <div class="run-hero__trace-wrap" aria-hidden="true">
        <RouteTrace
          points={latestSession.routeSvgPoints!}
          class="run-hero__trace"
          preserveAspectRatio="xMaxYMid meet"
        />
      </div>
    )}

    <div class="run-hero__title-group">
      <p class="run-hero__meta-line">{eyebrow}</p>
      <h1 id="run-hero-heading" class="run-hero__title">
        {sessionTitleParts.map((part) => part.isEmoji
          ? <span class="run-hero__title-emoji">{part.text}</span>
          : part.text
        )}
      </h1>
      {isRace && <p class="race-badge race-badge--hero">Race</p>}
      {variant === "home" && calloutParagraph && <p class="run-hero__dek">{calloutParagraph}</p>}
    </div>

  </div>

  <dl class="run-stat-row run-stat-row--cover">
    <div class="run-stat run-stat--primary">
      <dt>Distance</dt>
      <dd>{latestSession.distanceKm === null ? "—" : `${latestSession.distanceKm.toFixed(1)} km`}</dd>
    </div>
    <div class="run-stat run-stat--primary">
      <dt>Duration</dt>
      <dd>{latestSession.durationLabel}</dd>
    </div>
    <div class="run-stat run-stat--primary">
      <dt>Pace</dt>
      <dd>{latestSession.paceLabel ?? "—"}</dd>
    </div>
    <div class="run-stat">
      <dt>Conditions</dt>
      <dd class="run-condition">
        <WeatherGlyph kind={getWeatherKind(latestSession.weatherLabel)} className="run-condition__icon" />
        <span>{latestSession.weatherLabel ?? "—"}</span>
      </dd>
    </div>
  </dl>

  {variant === "detail" && latestSession.laps.length > 0 && (
    <div class="lap-preview">
      <div class="lap-preview__header">
        <p class="eyebrow lap-preview__label">Splits / {latestSession.laps.length} splits</p>
        {sessionPath && (
          <a class="lap-preview__link" href={sessionPath}>View full breakdown</a>
        )}
      </div>
      <div class="lap-table-wrap">
        <table class="lap-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Km</th>
              <th>Pace</th>
              <th>Time</th>
              <th>HR</th>
            </tr>
          </thead>
          <tbody>
            {latestSession.laps.map((lap) => (
              <tr>
                <td class="lap-table__num">{lap.lapNumber}</td>
                <td>{lap.distanceKm === null ? "—" : lap.distanceKm.toFixed(1)}</td>
                <td>{lap.paceLabel ?? "—"}</td>
                <td>{lap.durationLabel}</td>
                <td>{lap.averageHeartRate === null ? "—" : lap.averageHeartRate}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  {variant === "detail" && (
    <div class="session-reading session-reading--embedded">
      <div class="session-reading__column">
        <div class="session-reading__header">
          <p class="eyebrow">Reading</p>
          <h2>{coachFeedback.headline}</h2>
        </div>

        <div class="session-reading__body">
          {readingParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}

          {carryForward && (
            <p class="session-reading__callout">
              <strong>Carry forward.</strong> {carryForward}
            </p>
          )}

          {nextRunTitle && nextRunSummary && (
            <p class="session-reading__callout">
              <strong>What followed.</strong> {nextRunTitle}. {nextRunSummary}
            </p>
          )}
        </div>
      </div>
    </div>
  )}

</section>
