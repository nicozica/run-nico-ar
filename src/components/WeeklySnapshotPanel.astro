---
import type { WeeklySnapshot } from "../lib/data/types";

interface Props {
  weeklySnapshot: WeeklySnapshot;
}

const { weeklySnapshot } = Astro.props;
const maxDistance = Math.max(...weeklySnapshot.dailyDistanceKm.map((d) => d.distanceKm), 1);
---

<section class="panel weekly-panel training-row-card" aria-labelledby="weekly-heading">
  <p class="eyebrow">This week</p>
  <h2 id="weekly-heading">{weeklySnapshot.trainingStatus}</h2>

  <p class="weekly-summary">{weeklySnapshot.summary}</p>

  <dl class="weekly-meta">
    <div class="weekly-meta__item">
      <dt>Volume</dt>
      <dd>{weeklySnapshot.totalKm.toFixed(1)} km</dd>
    </div>
    <div class="weekly-meta__item">
      <dt>Runs</dt>
      <dd>{weeklySnapshot.runCount}</dd>
    </div>
    <div class="weekly-meta__item">
      <dt>Time</dt>
      <dd>{weeklySnapshot.totalTimeMinutes} min</dd>
    </div>
  </dl>

  <div class="trend trend--integrated" aria-label="Daily km this week">
    {weeklySnapshot.dailyDistanceKm.map((entry) => (
      <div class="trend__item">
        <span
          class="trend__bar"
          style={`--bar-scale: ${entry.distanceKm / maxDistance};`}
        ></span>
        <div class="trend__meta">
          {entry.distanceKm > 0 && (
            <span class="trend__value">{entry.distanceKm.toFixed(1)}</span>
          )}
          <span class="trend__label">{entry.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>
