---
import type { NextRun } from "../lib/data/types";

interface Props {
  nextRun: NextRun;
}

const { nextRun } = Astro.props;

const editorialTitlesByWorkoutType: Record<string, string> = {
  "Easy Run": "Easy aerobic miles",
  "Long Run": "Steady endurance work",
  Hills: "Strength on the climb",
  "Interval Session": "Controlled speed work",
  Race: "Race day execution",
  "Recovery Run": "Keep it light",
  Strides: "Fast but relaxed",
  "Tempo Session": "Sustained controlled effort",
  "Time Trial": "Benchmark effort",
};

function normalizeSessionLabel(value: string): string {
  return value
    .toLowerCase()
    .replace(/sessions/g, "session")
    .replace(/runs/g, "run")
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
}

const workoutType = nextRun.workout?.type ?? null;
const shouldUseEditorialFallback = workoutType
  ? normalizeSessionLabel(nextRun.name) === normalizeSessionLabel(workoutType)
  : false;
const displayTitle = shouldUseEditorialFallback
  ? workoutType
    ? editorialTitlesByWorkoutType[workoutType] ?? nextRun.name
    : nextRun.name
  : nextRun.name;
---

<section class="panel panel--accent next-run-panel training-row-card" aria-labelledby="next-run-heading">
  <div class="panel-heading panel-heading--tight">
    <p class="eyebrow">Next run</p>
    <h2 id="next-run-heading">{displayTitle}</h2>
  </div>

  <p class="panel-copy next-run-panel__summary">{nextRun.goal}</p>

  <dl class="next-run-stats next-run-stats--integrated">
    <div class="next-run-stat">
      <dt>Estimated duration</dt>
      <dd>{nextRun.estimatedDuration}</dd>
    </div>
    <div class="next-run-stat">
      <dt>Pace range</dt>
      <dd>{nextRun.paceRange}</dd>
    </div>
  </dl>

  {nextRun.workout && nextRun.workout.blocks.length > 0 && (
    <div class="next-run-workout" aria-label="Workout">
      <p class="eyebrow next-run-workout__label">Workout</p>
      <p class="next-run-workout__type">{nextRun.workout.type}</p>
      <ol class="next-run-workout__blocks">
        {nextRun.workout.blocks.map((block) => (
          <li class={block.startsWith("  ") ? "next-run-workout__block next-run-workout__block--nested" : "next-run-workout__block"}>
            {block.trim()}
          </li>
        ))}
      </ol>
    </div>
  )}
</section>
