---
import type { SiteCopy } from "../lib/data/types";

interface Props {
  site: SiteCopy;
  currentPath?: string;
}

const {
  currentPath = "/"
} = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand-link" href="/">
      <span class="brand-link__copy">
        <span class="brand-link__title">nico://run</span>
        <span class="brand-link__subtitle">training, interpreted</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a class:list={["site-nav__link", currentPath === "/" && "is-active"]} href="/">Home</a>
      <a class:list={["site-nav__link", currentPath === "/concept/" && "is-active"]} href="/concept/">Concept</a>
    </nav>
  </div>
</header>
