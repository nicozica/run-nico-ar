---
import type { RaceContext } from "../lib/data/types";

interface Props {
  raceContext: RaceContext;
}

const { raceContext } = Astro.props;
const nextRace = raceContext.nextRace;
---

<section class="panel panel--feature race-context-panel" aria-labelledby="race-context-heading">
  <div class="panel-heading panel-heading--tight">
    <p class="eyebrow">Next race</p>
    <h2 id="race-context-heading">{nextRace ? nextRace.title : "General build"}</h2>
    {nextRace && (
      <p class="race-context-panel__subtitle">
        <span>{nextRace.date}</span>
        <span aria-hidden="true">·</span>
        <span>{nextRace.distanceKm.toFixed(1)} km</span>
      </p>
    )}
  </div>

  {nextRace ? (
    <div class="race-context-panel__status">
      <div class="race-context-panel__countdown">
        <span class="race-context-panel__days">{nextRace.daysToRace}</span>
        <span class="race-context-panel__days-label">days to race</span>
      </div>

      <div class="race-context-panel__support">
        <div class="race-context-panel__phase-block">
          <p class="race-context-panel__meta-label">Current phase</p>
          <p class="race-context-panel__phase-value">{raceContext.currentPhase}</p>
        </div>

        {raceContext.mainGoal && (
          <div class="race-context-panel__goal-block">
            <p class="race-context-panel__meta-label">Main goal</p>
            <p class="race-context-panel__goal-title">{raceContext.mainGoal.title}</p>
            <p class="race-context-panel__goal-meta">
              <span>{raceContext.mainGoal.daysToRace} days out</span>
              {raceContext.mainGoal.targetPaceLabel && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>{raceContext.mainGoal.targetPaceLabel}</span>
                </>
              )}
            </p>
          </div>
        )}
      </div>
    </div>
  ) : (
    <p class="panel-copy panel-copy--compact">
      No race is set yet. The site can still read the session signal and keep the week pointed in the right direction.
    </p>
  )}

  {nextRace && (
    <div class="race-context-panel__relevance">
      <p class="race-context-panel__focus">{raceContext.focusLabel}</p>
      <p>{raceContext.sessionRelevance}</p>
    </div>
  )}

  {!nextRace && (
    <div class="race-context-panel__relevance">
      <p class="race-context-panel__focus">{raceContext.focusLabel}</p>
      <p>{raceContext.sessionRelevance}</p>
    </div>
  )}
</section>
